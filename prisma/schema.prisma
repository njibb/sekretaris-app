// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. DATABASE ANGGOTA & PENGURUS
// ==========================================
model Anggota {
  id        String   @id @default(cuid())
  nama      String
  divisi    String   // Cth: Humas, Danus, Acara
  jabatan   String   // Cth: Anggota, Koordinator, Ketua
  no_wa     String   // Berguna buat fitur auto-chat WA nanti
  alamat    String?
  isActive  Boolean  @default(true) // Status aktif/non-aktif pengurus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. E-SURAT (MASUK & KELUAR)
// ==========================================
model Surat {
  id          String   @id @default(cuid())
  tipe        TipeSurat 
  nomor_surat String   @unique // Cth: 001/KT-RW/VI/2026
  perihal     String
  tujuan_asal String   // KELUAR: Tujuan surat (Bapak RW). MASUK: Asal surat (Kelurahan)
  tanggal     DateTime
  file_url    String?  // Link PDF hasil generate atau link foto surat masuk
  keterangan  String?
  createdAt   DateTime @default(now())
}

enum TipeSurat {
  MASUK
  KELUAR
}

// ==========================================
// 3. NOTULENSI RAPAT DIGITAL
// ==========================================
model Notulensi {
  id           String   @id @default(cuid())
  agenda       String   // Cth: Rapat Persiapan 17-an
  tanggal      DateTime
  lokasi       String?
  daftar_hadir String   // Bisa simpan nama-nama yang hadir dipisah koma
  hasil_rapat  String   @db.Text // Teks panjang isi kesimpulan rapat
  notulis      String   // Nama yang mencatat
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==========================================
// 4. USER AUTHENTICATION
// ==========================================
enum UserRole {
  SEKRETARIS
  BENDAHARA
  KETUA
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   // Password harus di-hash (misal pakai bcrypt)
  role      UserRole @default(SEKRETARIS)
  createdAt DateTime @default(now())

  @@map("users")
}

model Rapat {
  id        String   @id @default(cuid())
  judul     String
  tanggal   DateTime
  pic       String   // Penanggung Jawab / Notulen
  keputusan String   @db.Text
  createdAt DateTime @default(now())
}

model kalenderKerja {
  id        String   @id @default(cuid())
  judul     String
  deskripsi String?
  tanggal   DateTime
  createdAt DateTime @default(now())
}
